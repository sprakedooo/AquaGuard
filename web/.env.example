# Firebase Web SDK config — Project Settings → General → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=

# Default device the dashboard opens on
VITE_DEFAULT_DEVICE_ID=pond-01
