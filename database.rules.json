{
  "rules": {

    // Each user owns their entire subtree — simple and airtight.
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },

    // Global deviceId → uid index.
    // Any authenticated user can READ a single entry to check if an ID is taken.
    // Only the owning user may CREATE or DELETE their own entry.
    "device-index": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },

    // Command queue: owner can enqueue & read; server (Admin SDK) processes.
    "commands": {
      "$deviceId": {
        ".read":  "auth != null && root.child('device-index').child($deviceId).val() === auth.uid",
        ".write": "auth != null && root.child('device-index').child($deviceId).val() === auth.uid"
      }
    },

    // Deny everything else by default.
    "$other": { ".read": false, ".write": false }
  }
}
